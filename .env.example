# Optional: add Hunter API key for person-level recruiter emails.
# Without this, script generates role-based aliases (careers@, recruiting@, etc.).
# HUNTER_API_KEY=your_key_here

# Target number of contacts to output.
# LEADS_TARGET=40

# Keep true to prioritize real person emails.
# If true and no HUNTER_API_KEY is set, script will warn and use alias fallback.
# REQUIRE_PERSON_EMAILS=true

# Hunter pagination controls (per company):
# HUNTER_LIMIT=10
# HUNTER_PAGES=3

# Final output cap and per-company cap:
# LEADS_TARGET=200
# MAX_PER_COMPANY=5

# --- Apollo.io (optional; for people search / enrichment) ---
# Create key: Apollo → Settings → Integrations → Apollo API → Connect → API Keys → Create new key.
# Docs: https://docs.apollo.io/docs/create-api-key
# Send requests with header: X-Api-Key: <your_key>
# APOLLO_API_KEY=your_apollo_key_here

# --- People Data Labs (optional; for person/company enrichment) ---
# Sign up: https://www.peopledatalabs.com/signup → Dashboard → API Keys → copy Active Key.
# Docs: https://docs.peopledatalabs.com/docs/create-an-account
# Most endpoints use header: X-Api-Key: <your_key> (or query param api_key= per endpoint docs).
# PDL_API_KEY=your_pdl_key_here
